# Networking
bindsym $mod+Shift+b exec /home/cody/Scripts/personal/remote-backup
#bindsym $mod+Shift+k exec killall polybar
bindsym $mod+Ctrl+F8 exec /home/cody/Scripts/personal/start_vpn
