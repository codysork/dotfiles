bindsym $mod+Ctrl+e exec st -e vim 
bindsym $mod+Ctrl+f exec firefox
bindsym $mod+Ctrl+j exec st -e vim ~/Documents/Journal/$(date +"%Y")/$(date +"%B")/$(date +"%Y-%m-%d").md
bindsym $mod+Ctrl+k exec keepassxc
bindsym $mod+Ctrl+m exec st -e cmus
bindsym $mod+Ctrl+p exec st -e castero
bindsym $mod+Ctrl+r exec st -e ranger ~/@/
bindsym $mod+Ctrl+u exec st -e yay -Syu
bindsym $mod+Ctrl+v exec st -e vim ~/@/@Inbox/new.temp
bindsym $mod+Ctrl+w exec wal -si ~/Pictures/Wallpapers --iterative -o ~/Scripts/keycolors
bindsym $mod+Ctrl+y exec st -e youtube-viewer -C --player=mpv --invidious
bindsym $mod+Ctrl+z exec st -e youtube-viewer -C --player=mpv --channels --invidious
#bindsym $mod+Ctrl+minus exec xinput set-prop 18 "Device Enabled" 0
#bindsym $mod+Ctrl+equals exec xinput set-prop 18 "Device Enabled" 1

# Common personal files
bindsym $mod+Ctrl+1 exec st -e vim ~/Sync/Todo/todo.txt
bindsym $mod+Ctrl+2 exec st -e vim ~/Sync/Todo/recur.txt
bindsym $mod+Ctrl+3 exec st -e vim ~/Sync/Todo/habits.txt
bindsym $mod+Ctrl+4 exec st -e vim ~/Sync/Todo/clock.txt
bindsym $mod+Ctrl+5 exec st -e vim ~/Sync/Todo/waiting.txt
bindsym $mod+Ctrl+6 exec st -e vim ~/Sync/Todo/someday.txt

# Common config files
bindsym $mod+Ctrl+F1 exec st -e vim ~/.xinitrc
bindsym $mod+Ctrl+F2 exec st -e vim ~/.config/i3/config
bindsym $mod+Ctrl+F3 exec st -e vim ~/.config/polybar/config
bindsym $mod+Ctrl+F4 exec st -e vim ~/.config/st/config.h
bindsym $mod+Ctrl+F5 exec st -e vim ~/.zshrc
bindsym $mod+Ctrl+F6 exec st -e vim ~/.vimrc
bindsym $mod+Ctrl+F11 exec st -e bluetoothctl
bindsym $mod+Ctrl+F12 exec st -e nmtui

# Startup
#-----------------
# Network Settings
exec --no-startup-id nm-applet

# Desktop Settings
exec --no-startup-id gnome-settings-daemon
exec compton
exec wal -si ~/Pictures/Wallpapers
exec_always --no-startup-id ~/.config/polybar/scripts/launch.sh &
exec redshift

